# ════════════════════════════════════════════════════════════════════════════
#  Fitness Care Bagerhat — .gitignore
#  Covers: Go backend · Flutter mobile · Docker · IDE · OS
# ════════════════════════════════════════════════════════════════════════════


# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example          # keep the example — it documents required vars
*.pem
*.key
*.p12
*.pfx
service-account*.json  # Firebase / GCP service account credentials
firebase-*.json
google-services.json   # Flutter Firebase config (contains API keys)
GoogleService-Info.plist


# ── Go ───────────────────────────────────────────────────────────────────────
# Compiled binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test artifacts
*.test
*.out
coverage.out
coverage.html
c.out

# Vendor directory (use Go modules instead)
vendor/

# Go workspace files (only needed for multi-module local dev)
go.work
go.work.sum


# ── Flutter / Dart ───────────────────────────────────────────────────────────
# Build outputs
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# Generated code (run `flutter pub run build_runner build` to regenerate)
*.g.dart
*.freezed.dart
*.gr.dart                # auto_route generated
*.config.dart
lib/gen/                 # flutter_gen output

# Android build artifacts
android/.gradle/
android/local.properties
android/app/debug/
android/app/profile/
android/app/release/
android/key.properties   # signing keystore passwords — NEVER commit
*.jks
*.keystore

# iOS build artifacts
ios/Pods/
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Runner/GeneratedPluginRegistrant.*

# macOS / Windows / Linux desktop
macos/Flutter/ephemeral/
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake

# Dart/Flutter cache
.pub-cache/
.pub/

# Coverage
coverage/
lcov.info


# ── Mobile Release Bundles ───────────────────────────────────────────────────
# Android
*.apk
*.aab                   # Android App Bundle
*.ap_

# iOS
*.ipa
*.dSYM
*.dSYM.zip
Payload/

# Signed artifacts
*-release.apk
*-debug.apk
*-profile.apk
app-release.apk
app-debug.apk


# ── Docker ───────────────────────────────────────────────────────────────────
# Local volume data (created by docker compose up)
postgres_data/
redis_data/
.docker/


# ── Database / Migrations ────────────────────────────────────────────────────
# Never ignore migration files — they are source of truth
# But ignore local DB dumps
*.sql.bak
*.dump
*.pgdump
*.sqlite
*.sqlite3
*.db


# ── IDE — VS Code ────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json   # keep recommended extensions list
!.vscode/settings.json     # keep project-specific settings (non-secret)
*.code-workspace


# ── IDE — JetBrains (GoLand, IntelliJ, Android Studio) ─────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/


# ── IDE — Xcode ──────────────────────────────────────────────────────────────
xcuserdata/
*.xcscmblueprint
*.xccheckout
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.hmap
*.ipa
*.xcuserstate
.DS_Store
*.DS_Store


# ── OS ───────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*


# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── Temporary / Misc ─────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.swp
*.swo
*~
.cache/


# ── What IS committed (explicit whitelist for generated files) ───────────────
# sqlc generated code — committed so consumers don't need sqlc installed
!internal/database/sqlc/

# Swagger generated docs — committed so Swagger UI works without running swag
!docs/docs.go
!docs/swagger.json
!docs/swagger.yaml
